# local-llmops runtime config — copy to .env, do not commit
# Two-tier llama.cpp serving on a single RTX 3080 10 GiB

# --- Bind ----------------------------------------------------------------
# Tailscale IPv4 of this host. Endpoints are deliberately *not* exposed on the LAN.
LLM_BIND_HOST=100.114.124.62
EXEC_PORT=8080
SMART_PORT=8081

# --- Models --------------------------------------------------------------
# Pre-download GGUFs into LLM_GGUF_DIR before bringing up containers:
#   curl -L -o "$LLM_GGUF_DIR/Qwen3.5-4B-UD-Q4_K_XL.gguf" \
#     https://huggingface.co/unsloth/Qwen3.5-4B-GGUF/resolve/main/Qwen3.5-4B-UD-Q4_K_XL.gguf
# (llama.cpp's `-hf` shorthand needs a manifest the unsloth repos don't ship,
# so we mount the GGUF directory and use `-m` instead.)
LLM_GGUF_DIR=/home/adam/llm-models/gguf
EXEC_MODEL_FILE=Qwen3.5-4B-UD-Q4_K_XL.gguf
EXEC_ALIAS=local-qwen-exec
SMART_MODEL_FILE=Qwen3.5-9B-UD-Q4_K_XL.gguf
SMART_ALIAS=local-qwen-smart

# --- Context / KV --------------------------------------------------------
# Spec-recommended starting points; ratchet down if either OOMs.
EXEC_CTX_SIZE=32768
EXEC_KV_TYPE=q8_0
SMART_CTX_SIZE=16384
SMART_KV_TYPE=q8_0

# --- Image / cache -------------------------------------------------------
LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda

# --- Optional auth -------------------------------------------------------
# Only needed if HF rate-limits unauth pulls or for gated models. Qwen3.5 is open.
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
